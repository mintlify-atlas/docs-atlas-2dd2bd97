  "keyFeatures": [
    "Multi-tenant architecture with automatic data isolation per business",
    "Product catalog management with SKU and price tracking",
    "Service catalog management with descriptions and pricing",
    "Real-time inventory tracking with min/max stock thresholds",
    "Stock movement logging (IN/OUT) with reason tracking",
    "Customer relationship management (CRM) with contact info",
    "JWT-based authentication with bcrypt password hashing",
    "Dashboard overview with key business metrics",
    "Protected REST API with tenant-scoped data access",
    "Supabase integration for frontend authentication"
  ],
  "publicApiSurface": [
